{
  "name": "sooryas-web",
  "version": "1.0.0",
  "description": "Mobile-first internal parlour operations app for Sooryas Skin Hair and Makeup.",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:reset:dev": "node scripts/reset-dev-db.js",
    "test": "node --import ./tests/setup-env.js --test --test-concurrency=1",
    "coverage": "node --import ./tests/setup-env.js --experimental-test-coverage --test --test-concurrency=1",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed",
    "test:ui:install": "playwright install chromium"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
