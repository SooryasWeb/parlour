# Vercel + Supabase production
# Use Supabase's Transaction pooler connection string for serverless functions.
# Example shape:
# DATABASE_URL=postgres://postgres.<project-ref>:<password>@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=
PGPOOL_MAX=1
SESSION_SECRET=replace-with-a-long-random-secret
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Local/dev break-glass only. Do not set this in production after Google auth is active.
ALLOW_PASSWORD_LOGIN=false

# Local development with docker-compose PostgreSQL
PGHOST=localhost
PGPORT=5432
PGUSER=soorya_admin
PGPASSWORD=soorya_password
PGDATABASE=sooryas_parlour_dev
