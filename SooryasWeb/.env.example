# Local development with docker-compose PostgreSQL.
PGHOST=localhost
PGPORT=5432
PGUSER=soorya_admin
PGPASSWORD=soorya_password
PGDATABASE=sooryas_parlour_dev

# Required in production.
SESSION_SECRET=replace-with-a-long-random-secret

# GoDaddy Node.js beta hosting with managed MySQL.
# GoDaddy injects these automatically when its managed database is attached.
# When DB_HOST is present, the root Node app uses MySQL instead of PostgreSQL.
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

# First deploy only if the MySQL database is empty and should be seeded.
# Set to false or remove after schema creation.
ALLOW_SCHEMA_INIT=false
